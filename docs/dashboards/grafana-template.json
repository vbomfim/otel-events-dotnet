{
  "uid": null,
  "title": "OtelEvents — Performance Dashboard",
  "description": "Auto-generated Grafana dashboard template for OtelEvents schemas. Covers HTTP request rate, error rate, duration percentiles, and health status. Customize by importing into Grafana or regenerating from your schema with SchemaMetricsDashboardGenerator.",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "10s",
  "tags": ["otel-events", "auto-generated"],
  "annotations": {
    "list": []
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "default",
          "value": "default"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "description": "Total HTTP requests received per second",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(otel_http_request_received_count_total[$__rate_interval])) by (httpMethod)",
          "legendFormat": "{{httpMethod}}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP Error Rate",
      "description": "Total HTTP request errors per second",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(otel_http_request_error_count_total[$__rate_interval])) by (httpMethod, errorType)",
          "legendFormat": "{{httpMethod}} {{errorType}}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "errors/s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HTTP Request Duration Percentiles",
      "description": "HTTP request processing duration (p50, p95, p99)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(otel_http_request_duration_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p50",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(otel_http_request_duration_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p95",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(otel_http_request_duration_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p99",
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "HTTP Response Rate by Status Code",
      "description": "Total HTTP responses per second grouped by method and status code",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(otel_http_response_count_total[$__rate_interval])) by (httpMethod, httpStatusCode)",
          "legendFormat": "{{httpMethod}} {{httpStatusCode}}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP Response Size Percentiles",
      "description": "HTTP response body size distribution (p50, p95, p99)",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(otel_http_response_size_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p50",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(otel_http_response_size_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p95",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(otel_http_response_size_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p99",
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Health Status Changes",
      "description": "Application health state changes (from lifecycle schema)",
      "gridPos": { "x": 12, "y": 16, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(app_health_changes_total[$__range])) by (currentStatus)",
          "legendFormat": "{{currentStatus}}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Lifecycle Transitions",
      "description": "Application lifecycle phase transitions (from lifecycle schema)",
      "gridPos": { "x": 18, "y": 16, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(app_lifecycle_transitions_total[$__range]))",
          "legendFormat": "transitions",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Startup Duration",
      "description": "Application startup duration histogram (from lifecycle schema)",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(app_startup_durationMs_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p50",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(app_startup_durationMs_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p95",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(app_startup_durationMs_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p99",
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    }
  ]
}
